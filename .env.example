# Echo-audiobook 环境变量配置模板
# 用法:复制本文件为 .env,填入真实的 API key
# 注意:.env 已加入 .gitignore,不会被提交到 GitHub

# ===== AI 模型 API =====
# DeepSeek (主用,便宜)
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 智谱 GLM (备用)
# 申请地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# Kimi (备用)
# 申请地址: https://platform.moonshot.cn/
KIMI_API_KEY=

# ===== TTS API (M7 阶段使用) =====
# 阿里云 NLS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_APP_KEY=

# 字节火山引擎
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=

# ===== GPT-SoVITS 服务地址 (M7 阶段使用) =====
# 如果你本地部署了 GPT-SoVITS,填它的 API 地址
GPTSOVITS_API_URL=http://localhost:9880
